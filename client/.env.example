# =====================================================
# YEC Saller Frontend - Environment Variables
# =====================================================
# Copy this file to .env for local development:
#   cp .env.example .env
# =====================================================

# Local development: Backend Express server 5000-portda
VITE_API_URL=http://localhost:5000/api

