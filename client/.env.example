# =====================================================
# YEC Saller Frontend - Environment Variables
# =====================================================
# Copy this file to .env for local development:
#   cp .env.example .env
# =====================================================

# Local development: Backend Express server 5000-portda
VITE_API_URL=http://localhost:5000/api

# =====================================================
# VERCEL PRODUCTION (majburiy!)
# =====================================================
# Frontend va backend alohida Vercel projectlarida.
# Vercel Dashboard → Frontend project → Settings → 
# Environment Variables → qo'shing:
#   Key: VITE_API_URL
#   Value: https://yec-server.vercel.app/api
#
# Agar bu o'rnatilmasa, frontend o'z domainiga /api 
# deb request yuboradi va ERR_CONNECTION_REFUSED chiqadi.
# =====================================================