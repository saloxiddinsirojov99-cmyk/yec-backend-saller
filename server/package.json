{
  "name": "yec-gilam-server",
  "version": "2.0.0",
  "description": "YEC Gilam Backend API - Prisma 7 + PostgreSQL (Neon)",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "db:push": "npx prisma db push --config=./prisma/prisma.config.ts",
    "db:seed": "node prisma/seed.js",
    "db:studio": "npx prisma studio",
    "db:generate": "npx prisma generate --schema=./prisma/schema.prisma",
    "vercel-build": "npm run db:generate",
    "postinstall": "npm run db:generate",
    "test": "node tests/integration/api.test.js",
    "test:health": "node -e \"require('http').get('http://localhost:5000/api/health', r => {let d='';r.on('data',c=>d+=c);r.on('end',()=>console.log(JSON.parse(d)))})\""
  },
  "prisma": {
    "schema": "./prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.10",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "prisma": "^7.8.0"
  }
}
