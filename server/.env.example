# YEC Gilam Backend - Environment Variables
# Copy to .env for local development: cp .env.example .env

# PostgreSQL connection (Neon, Render, or local)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# JWT signing secret (minimum 16 characters)
JWT_SECRET=change-this-to-a-long-random-secret

# Server port (Render sets PORT automatically)
PORT=5000

# Frontend URL for CORS (Vercel production frontend)
FRONTEND_URL=http://localhost:5173

# Optional SMTP for user notification emails
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=
